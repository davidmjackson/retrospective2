NODE_ENV=production
PORT=3001

# Required in production. Generate a long random value and keep it private.
RETRO_AUTH_SECRET=replace-with-a-long-random-secret

# Required in production. Must be exactly 5 lowercase letters or digits.
RETRO_ADMIN_KEY=abc12

# Comma-separated browser origins allowed to connect, including WebSockets.
RETRO_ALLOWED_ORIGINS=https://retro.example.com

# Store the live SQLite database outside the Git working tree.
RETRO_DB_PATH=/var/lib/retrospective/retros.db

# Optional session and housekeeping settings.
RETRO_AUTH_TTL_HOURS=24
RETRO_RETENTION_DAYS=
RETRO_LOGIN_RATE_LIMIT_MAX=20
RETRO_LOGIN_RATE_LIMIT_WINDOW_MS=900000
