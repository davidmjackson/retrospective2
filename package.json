{
  "name": "retrospective",
  "version": "1.0.0",
  "description": "Simple realtime retrospective board",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "node --test tests/theme-drift.test.js tests/theme-contrast.test.js tests/db-schema.test.js tests/upgrade-auth.test.js tests/company-access.test.js tests/return-to-suite.test.js",
    "test:e2e": "playwright test",
